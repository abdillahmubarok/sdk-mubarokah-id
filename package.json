{
  "name": "@mubarokah/auth-js",
  "version": "1.0.0",
  "description": "TypeScript SDK for integrating Mubarokah ID SSO (OAuth 2.0 + PKCE) into React/Next.js applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mubarokah",
    "sso",
    "oauth2",
    "pkce",
    "react",
    "nextjs",
    "authentication"
  ],
  "author": "Mubarokah",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mubarokah/auth-js"
  },
  "homepage": "https://docs.mubarokah.com"
}

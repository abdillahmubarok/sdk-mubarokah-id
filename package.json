{
  "name": "mubarokah-id-sdk",
  "version": "1.0.2",
  "description": "TypeScript SDK for Mubarokah ID SSO - OAuth 2.0 integration made easy",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.mts",
        "default": "./dist/react/index.mjs"
      },
      "require": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "example": "npx tsx examples/express-app/server.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mubarokah",
    "mubarokah-id",
    "sso",
    "oauth",
    "oauth2",
    "authentication",
    "laravel-passport",
    "typescript",
    "sdk"
  ],
  "author": "Mubarokah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdillahmubarok/sdk-mubarokah-id.git"
  },
  "bugs": {
    "url": "https://github.com/abdillahmubarok/sdk-mubarokah-id/issues"
  },
  "homepage": "https://github.com/abdillahmubarok/sdk-mubarokah-id#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "react": "^19.2.5",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
